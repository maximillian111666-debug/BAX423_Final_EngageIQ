# ── Required for LLM features (explain / suggest actions) ──────────────
# DeepSeek (recommended — cheapest, fully OpenAI-compatible)
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Alternatively, Qwen:
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# Alternatively, Moonshot/Kimi:
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k

# ── GitHub API (optional — increases data freshness) ───────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Reddit API (optional) ──────────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=EngageIQ/1.0 by YourUsername

# ── Database path (default: data/engageiq.db) ─────────────────────────
# DB_PATH=data/engageiq.db
